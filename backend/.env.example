# GitHub token is optional - leave empty to use unauthenticated requests (60 req/hour limit)
# Get a token at: https://github.com/settings/tokens (select 'public_repo' scope)
GITHUB_TOKEN=

# OpenRouter API key (required for LLM features)
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Database (PostgreSQL)
DATABASE_URL
# E.g. from Render: postgresql://user:password@hostname/dbname
DATABASE_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
